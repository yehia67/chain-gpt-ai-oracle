generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OracleActionType {
  BUY
  SELL
  NO_ACTION
}

enum TaskValidationStatus {
  NOT_REQUIRED
  PENDING
  VERIFIED
  REJECTED
  FAILED
}

enum TaskExecutionStatus {
  PENDING
  PROCESSING
  NO_ACTION
  EXECUTED
  REJECTED
  FAILED
}

model OracleTask {
  taskId               String               @id @db.VarChar(64)
  action               OracleActionType
  sentiment            String?              @db.VarChar(16)
  confidence           Float?
  rawResponse          String?
  dataHash             String?              @db.VarChar(66)
  validationRequestId  BigInt?
  validationStatus     TaskValidationStatus @default(NOT_REQUIRED)
  executionStatus      TaskExecutionStatus  @default(PENDING)
  txHash               String?              @db.VarChar(66)
  x402ConditionHash    String?              @db.VarChar(66)
  x402ConditionSignature String?            @db.VarChar(132)
  x402SettlementRef    String?              @db.VarChar(191)
  x402ExecutionMode    String?              @db.VarChar(32)
  validationProofUri   String?
  feedbackUri          String?
  errorMessage         String?
  newsPayload          Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([validationStatus, executionStatus])
  @@index([createdAt])
}
