# ChainGPT
CHAINGPT_API_KEY=sk-***

# Ethereum / Sepolia
RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
PRIVATE_KEY=0x...
CHAIN_ID=11155111

# ERC-8004 Sepolia canonical registries (from erc-8004/erc-8004-contracts)
A2A_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
A2A_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Validation + trade executor (custom contracts deployed on Sepolia for this project)
# NOTE: current backend/trade flow requires the project-local ValidationRegistry ABI.
# Official ERC-8004 ValidationRegistry Sepolia exists (0x8004Cb1BF31DAf7788923b405b754f57acEB4272)
# but is not wire-compatible with this app's current request/response + isVerified flow.
A2A_VALIDATION_REGISTRY_ADDRESS=0xb40bc2358378199936236266CB10D933D5a547bD
CONTRACT_ADDRESS=0x7260eE51998454958D4075aF9e84e66ff7Aa7295

# Agent identity minted on ERC-8004 IdentityRegistry (required for reputation calls)
# Replace with your minted value from: AGENT_URI=ipfs://... pnpm agent:register
A2A_AGENT_ID=0

# Optional: override validator address if different from PRIVATE_KEY signer
VALIDATOR_ADDRESS=0x...

# Storage + DB
PINATA_JWT=eyJ...
# Local host run (non-docker):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_oracle?schema=public
# Docker Compose run (container-to-container):
DATABASE_URL_DOCKER=postgresql://postgres:postgres@db:5432/ai_oracle?schema=public

# Worker
WORKER_POLL_MS=10000

# X402 verifiable execution layer
# local: verify + settle signed condition in-process before/after tx
# facilitator: call external X402 facilitator endpoints (/verify + /settle)
X402_EXECUTION_MODE=local
X402_FACILITATOR_URL=https://facilitator.0xmeta.ai/v1
X402_CONDITION_TTL_SEC=300
