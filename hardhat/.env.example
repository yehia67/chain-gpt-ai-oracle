RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID 
PRIVATE_KEY=0xYOUR_SEPOLIA_PRIVATE_KEY

# Optional overrides for hardhat/scripts/deploy-sepolia.ts
# If omitted, script uses canonical ERC-8004 Sepolia addresses for identity/reputation.
A2A_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
A2A_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Optional: pre-existing validation registry (otherwise script deploys project-local one)
A2A_VALIDATION_REGISTRY_ADDRESS=0x
